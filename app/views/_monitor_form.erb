<% known_models = ["mistralai/mistral-small-3.1-24b-instruct:free", "openai/gpt-5-nano"] %>
<% current_model = monitor&.dig(:model) || "mistralai/mistral-small-3.1-24b-instruct:free" %>
<% is_custom_model = monitor && !known_models.include?(current_model) %>
<% run_interval_value = monitor ? ActiveSupport::Duration.build(monitor[:run_interval].to_i).inspect : "8 hours" %>

<form method="POST" action="<%= action %>">
  <div>
    <input type="url" id="url" name="url" value="<%= monitor&.dig(:url) %>" placeholder="URL to monitor" required style="width: 100%; box-sizing: border-box" />
  </div>

  <div>
    <p style="line-height: 39px">
      <label for="determine">Determine...</label>
      <textarea style="display: inline-block; vertical-align: middle" id="determine" name="determine" required><%= monitor ? monitor[:determine] : "whether " %></textarea>
    </p>
  </div>

  <div>
    <label for="extra_instructions">Extra instructions (optional):</label>
    <textarea
      id="extra_instructions"
      name="extra_instructions"
      placeholder="Add any extra context or instructions to help the model decide when things are ambiguous"
      style="width: 100%; box-sizing: border-box"><%= monitor&.dig(:extra_instructions) %></textarea>
  </div>

  <div>
    <label for="model">Using model:</label>
    <select id="model" name="model">
      <% known_models.each do |m| %>
        <option value="<%= m %>" <%= "selected" if current_model == m %>><%= m %></option>
      <% end %>
      <option value="other" <%= "selected" if is_custom_model %>>Other…</option>
    </select>
    <div id="custom_model_div" style="display: none; margin-top: 6px;">
      <input
        type="text"
        id="custom_model"
        name="custom_model"
        value="<%= current_model if is_custom_model %>"
        placeholder="OpenRouter model ID"
        style="width: 100%; box-sizing: border-box"
      />
    </div>
  </div>

  <div>
    <label for="run_interval">Every:</label>
    <input
      type="text"
      id="run_interval"
      name="run_interval"
      value="<%= run_interval_value %>"
      placeholder="How often to run the model"
      required style="width: 100%; box-sizing: border-box"
    />
  </div>

  <div>
    <button type="submit"><%= submit_label %></button>
    <% if cancel_url %>
      <a href="<%= cancel_url %>">Cancel</a>
    <% end %>
  </div>
</form>

<script>
  function showHideCustomModelDiv() {
    const value = document.querySelector('select[name=model]').value;
    const otherModelDiv = document.getElementById('custom_model_div');
    otherModelDiv.style.display = value === 'other' ? 'block' : 'none';
  }

  document.querySelector('select[name=model]').addEventListener('change', showHideCustomModelDiv);
  document.addEventListener('DOMContentLoaded', showHideCustomModelDiv);
</script>
