<style>
  .screenshot {
    width: 200px;
    max-height: 200px;
    object-fit: cover;
    object-position: top;
    aspect-ratio: initial;
  }

  .screenshot-mobile {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    object-position: top;
    aspect-ratio: initial;
  }

  .paused {
    background-color: #fff3e0;
    padding: 10px;
    border: 1px solid #ffe0b2;
    border-radius: 4px;
  }
</style>

<% if @monitor[:paused] %>
  <div class="paused">
    This monitor is paused.
  </div>
<% end %>

<h1>Determine <%= @monitor[:determine] %></h1>

<div>
  <div><strong>URL</strong>: <a href="<%= @monitor[:url] %>" target="_blank"><%= @monitor[:url] %></a></div>
  <div><strong>Interval</strong>: <%= ActiveSupport::Duration.build(@monitor[:run_interval].to_i).inspect %></div>
  <div><strong>Model</strong>: <span style="font-family: monospace"><%= @monitor[:model] %></span></div>
</div>

<% if @monitor[:extra_instructions].present? %>
  <p><em><%= @monitor[:extra_instructions] %></em></p>
<% end %>

<br>

<div style="display: flex; gap: 10px;">
  <form method="post" action="/monitors/<%= @monitor[:id] %>/action">
    <button name="action" value="run" type="submit" style="background-color: #c2f3bb;">
      Run now
    </button>
  </form>

  <% if @monitor[:paused] %>
    <form method="post" action="/monitors/<%= @monitor[:id] %>/action">
      <button name="action" value="resume" type="submit" style="background-color: #b2dfff;">Resume</button>
    </form>
  <% else %>
    <form method="post" action="/monitors/<%= @monitor[:id] %>/action">
      <button name="action" value="pause" type="submit" style="background-color: #ffe0b2;">Pause</button>
    </form>
  <% end %>
</div>

<% if @runs.empty? %>
  <p>No runs yet.</p>
<% else %>
  <table class="desktop">
    <thead>
    <tr>
      <th style="width: 200px">Run</th>
      <th>Rationale</th>
      <th style="width: 200px">Screenshot</th>
    </tr>
    </thead>
    <tbody id="runs-table-body">
    <% @runs.each_with_index do |run, idx| %>
      <%= partial(:_run_row, run: run, loading: idx < 10 ? "eager" : "lazy") %>
    <% end %>
    <% if @has_more %>
      <tr
        id="desktop-scroll-sentinel"
        hx-get="/monitors/<%= @monitor[:id] %>/runs?format=desktop&offset=<%= @runs.length %>"
        hx-trigger="intersect once"
        hx-swap="outerHTML"
        style="height: 1px; max-height: 1px; overflow: hidden;"
      ><td colspan="3" style="padding: 0; border: 0; height: 1px;"></td></tr>
    <% end %>
    </tbody>
  </table>

  <div class="mobile" id="runs-mobile-list">
    <% @runs.each do |run| %>
      <%= partial(:_run_card, run: run) %>
    <% end %>
    <% if @has_more %>
      <div
        id="mobile-scroll-sentinel"
        hx-get="/monitors/<%= @monitor[:id] %>/runs?format=mobile&offset=<%= @runs.length %>"
        hx-trigger="intersect once"
        hx-swap="outerHTML"
        style="height: 1px;"
      ></div>
    <% end %>
  </div>
<% end %>
